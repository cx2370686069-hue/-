{
  "@platforms": [
    "android",
    "iPhone",
    "iPad"
  ],
  "id": "",
  "name": "固始县外卖骑手端",
  "version": {
    "name": "1.0.0",
    "code": "100"
  },
  "description": "骑手专用接单配送应用",
  "developer": {
    "name": "",
    "email": "",
    "url": ""
  },
  "permissions": {
    "Speech": {},
    "UniNView": {
      "description": "UniNView原生渲染"
    }
  },
  "plus": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "splashscreen": {
      "target": "id:1",
      "autoclose": true,
      "waiting": true,
      "delay": 0
    },
    "popGesture": "close",
    "launchwebview": {
      "id": "1",
      "kernel": "WKWebview"
    },
    "usingComponents": true,
    "nvueCompiler": "uni-app",
    "compilerVersion": 3,
    "statusbar": {
      "immersed": "supportedDevice",
      "style": "light",
      "background": "#1890FF"
    },
    "allowsInlineMediaPlayback": true,
    "distribute": {
      "plugins": {
        "audio": {
          "mp3": {
            "description": "Android平台录音支持MP3格式文件"
          }
        }
      }
    },
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    },
    "uni-app": {
      "control": "uni-v3",
      "vueVersion": "3",
      "compilerVersion": "5.07",
      "nvueCompiler": "uni-app",
      "renderer": "auto",
      "nvue": {
        "flex-direction": "column"
      },
      "nvueLaunchMode": "normal",
      "webView": {
        "minUserAgentVersion": "49.0"
      }
    },
    "tabBar": {
      "position": "bottom",
      "color": "#999999",
      "selectedColor": "#1890FF",
      "borderStyle": "rgba(0,0,0,0.4)",
      "blurEffect": "none",
      "fontSize": "10px",
      "iconWidth": "24px",
      "spacing": "3px",
      "height": "50px",
      "list": [
        {
          "pagePath": "pages/index/index",
          "text": "📱 工作台"
        },
        {
          "pagePath": "pages/orders/index",
          "text": "📋 订单"
        },
        {
          "pagePath": "pages/profile/index",
          "text": "👤 我的"
        }
      ],
      "backgroundColor": "#ffffff",
      "selectedIndex": 0,
      "shown": true
    }
  },
  "app-harmony": {
    "useragent": {
      "value": "uni-app",
      "concatenate": true
    },
    "safearea": {
      "background": "#ffffff",
      "bottom": {
        "offset": "auto"
      }
    }
  },
  "launch_path": "__uniappview.html"
}