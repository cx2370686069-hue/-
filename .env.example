# 复制本文件为 .env 并填入真实值；切勿把真实凭据提交到仓库

# 服务器
PORT=3000
NODE_ENV=development

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_NAME=replace_me

# JWT（生产环境必须使用 >=64 字节强随机字符串，例如 `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`）
JWT_SECRET=replace_me_with_strong_random_secret
JWT_EXPIRES_IN=2h
JWT_ISSUER=gushi-waimai
JWT_AUDIENCE=gushi-waimai-clients

# 跨域：生产环境务必配置为前端域名白名单（逗号分隔），不要使用 *
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# 天地图
TIANDITU_TK=replace_me

# 支付
# mock = 仅本地开发联调；生产环境请设置为 wechat / alipay
PAYMENT_MODE=mock
# 仅在 mock 模式且 NODE_ENV != production 才会生效
PAYMENT_ENABLE_INTERNAL_MOCK_CONFIRM=false
PAYMENT_AUTO_CONFIRM_ON_ORDER_PAY=false
PAYMENT_AUTO_CONFIRM_ON_ORDER_CREATE=false
# 用于支付回调的辅助校验 token；生产环境必填
PAYMENT_NOTIFY_TOKEN=replace_me_with_strong_random_token

# 管理端默认账号（仅初始化使用）
ADMIN_DEFAULT_PHONE=
ADMIN_DEFAULT_PASSWORD=
